{
    "name": "pi-channels",
    "version": "0.2.0",
    "private": true,
    "description": "Inter-session agent communication for the pi coding agent",
    "keywords": ["pi-package", "channels", "multi-agent", "communication"],
    "workspaces": ["packages/*"],
    "scripts": {
        "build": "npm run build -w agent-channels",
        "test:lib": "npm test -w agent-channels",
        "test:ext": "npm test -w pi-channels",
        "test": "npm run test:lib && npm run test:ext"
    },
    "pi": {
        "extensions": ["packages/pi-channels/extensions"]
    },
    "license": "MIT"
}
